table{border-collapse:collapse;width:100%;}
th,td{border:1px solid #bbb;padding:5px 8px;vertical-align:middle;}
.titulo{background:#10069F;color:#fff;font-size:14px;font-weight:bold;text-align:center;height:40px;}
.subtitulo{background:#e8eaf6;color:#10069F;font-size:11px;font-weight:bold;text-align:center;}
.cabecera{background:#1a237e;color:#fff;font-weight:bold;text-align:center;font-size:10px;}
.modulo-header{background:#283593;color:#fff;font-weight:bold;font-size:12px;text-align:left;padding:8px;}
.id-cell{background:#e8eaf6;font-weight:bold;color:#10069F;}
.pasa{background:#e8f5e9;color:#1b5e20;font-weight:bold;text-align:center;}
.falla{background:#ffebee;color:#b71c1c;font-weight:bold;text-align:center;}
