.media{background:#e3f2fd;color:#0d47a1;font-weight:bold;text-align:center;}
.baja{background:#f3e5f5;color:#4a148c;font-weight:bold;text-align:center;}
.fila-par{background:#f5f5f5;}
.fila-impar{background:#ffffff;}
.pe{background:#f3e5f5;color:#4a148c;font-weight:bold;text-align:center;font-size:10px;}
.vl{background:#e8f5e9;color:#1b5e20;font-weight:bold;text-align:center;font-size:10px;}
